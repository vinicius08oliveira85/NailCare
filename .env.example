# Supabase (NailCare sync). Prefix VITE_ is required for Vite to expose to the client.
# Get URL and anon key from Supabase Dashboard: Settings > API.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Service role (backend / Vercel): usado pela API /api/subscribe (e pelo cron de notificações quando reativado).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Notificações push: desativadas por padrão (limite de cron na Vercel). Para ativar depois: VITE_PUSH_ENABLED=true e recriar o cron em vercel.json.
# VITE_PUSH_ENABLED=""

# Web Push (só necessário se reativar notificações): gerar com `npx web-push generate-vapid-keys`.
# VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
# VITE_VAPID_PUBLIC_KEY="..."

# Cron (só necessário se reativar notificações e adicionar crons em vercel.json).
# CRON_SECRET="random-secret"

# Opcional: URL base do app (ex.: https://nailcare.vercel.app). Se vazio, usa origem atual para /api/subscribe.
VITE_APP_URL=""

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
